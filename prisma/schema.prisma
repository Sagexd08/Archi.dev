generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TabKind {
  api
  process
  infrastructure
  schema
  requestTab
  other
}

enum TransactionKind {
  monthly_free_grant
  manual_topup
  dummy_payment
  razorpay_payment
  usage
  refund
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  trialing
}

model User {
  id            String              @id @default(cuid())
  email         String              @unique
  name          String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  creditBalance CreditBalance?
  documents     Document[]
  documentSets  DocumentSet[]
  transactions  CreditTransaction[]
  subscription  Subscription?
}

model Plan {
  id            String         @id @default(cuid())
  name          String         @unique
  displayName   String
  priceMonthly  Float          @default(0)
  priceYearly   Float          @default(0)
  credits       BigInt         @default(500)
  maxProjects   Int            @default(3)
  maxSeats      Int            @default(1)
  features      Json
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id])
  planId             String
  plan               Plan               @relation(fields: [planId], references: [id])
  status             SubscriptionStatus @default(active)
  billingInterval    String             @default("monthly")
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model CreditBalance {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  availableCredits    BigInt   @default(0)
  monthlyFreeCredits  BigInt   @default(500)
  freeResetDayOfMonth Int      @default(1)
  lastResetAt         DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CreditTransaction {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  kind      TransactionKind
  amount    BigInt
  note      String?
  createdAt DateTime        @default(now())
}

// Idempotency guard — one row per razorpay_payment_id, prevents double-crediting
model RazorpayPayment {
  id                String    @id @default(cuid())
  razorpayPaymentId String    @unique
  razorpayOrderId   String
  userId            String
  plan              String
  amountPaise       Int
  status            String    @default("pending") // pending | captured | failed
  processedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Document {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  tab           TabKind
  title         String
  version       Int          @default(1)
  content       Json
  metadata      Json?
  documentSetId String?
  documentSet   DocumentSet? @relation(fields: [documentSetId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model DocumentSet {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  tab       TabKind
  name      String
  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
